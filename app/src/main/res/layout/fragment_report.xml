<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        app:elevation="0dp">
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="用户报表"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <ImageButton
                    android:id="@+id/btnHelp"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_nav_help"
                    android:tint="@color/primary"
                    android:padding="8dp"
                    android:contentDescription="帮助" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStudentManage"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="学生管理"
                    android:textSize="13sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="18dp"
                    app:icon="@android:drawable/ic_menu_myplaces"
                    app:iconSize="16dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="88dp"
        android:clipToPadding="false">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <!-- 渐变统计横幅 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="20dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/bg_header_gradient">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="学习总览"
                        android:textSize="12sp"
                        android:textColor="#B3FFFFFF"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvStatUsers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="总人数"
                                android:textSize="12sp"
                                android:textColor="#B3FFFFFF" />
                        </LinearLayout>
                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="#33FFFFFF"
                            android:layout_marginHorizontal="8dp" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvStatExams"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="考试次数"
                                android:textSize="12sp"
                                android:textColor="#B3FFFFFF" />
                        </LinearLayout>
                        <View
                            android:layout_width="1dp"
                            android:layout_height="48dp"
                            android:background="#33FFFFFF"
                            android:layout_marginHorizontal="8dp" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tvStatQuestions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="答题总数"
                                android:textSize="12sp"
                                android:textColor="#B3FFFFFF" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 二级统计行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardWrong"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#10060;"
                            android:textSize="24sp"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:id="@+id/tvStatWrong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/error" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="待攻克错题"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击查看排名 ›"
                            android:textSize="11sp"
                            android:textColor="@color/primary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardScoreRanking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/card_stroke"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#127942;"
                            android:textSize="24sp"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:id="@+id/tvStatBanks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="做题排名"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="2dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击查看排名 ›"
                            android:textSize="11sp"
                            android:textColor="@color/primary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 用户汇总报表区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="用户考试汇总"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRefreshReport"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="刷新"
                    android:textSize="12sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="16dp"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>

            <!-- 排序按钮行 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="10dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="排序："
                        android:textSize="13sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginEnd="6dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSortAvg"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="平均分"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="16dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSortMax"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="最高分"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="16dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSortName"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="姓名"
                        android:textSize="12sp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="16dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                </LinearLayout>
            </HorizontalScrollView>

            <!-- 用户卡片列表容器（RecyclerView 虚拟化，防止大量用户时 OOM） -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recordListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never" />

            <TextView
                android:id="@+id/tvNoRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="暂无考试记录&#10;在网页端完成练习后将显示在这里"
                android:textSize="13sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:paddingVertical="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>