<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/background">

	<com.google.android.material.appbar.AppBarLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:background="@color/surface"
		app:elevation="2dp">

		<androidx.appcompat.widget.Toolbar
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			android:paddingHorizontal="8dp">

			<LinearLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal"
				android:gravity="center_vertical">

				<ImageView
					android:id="@+id/btnBack"
					android:layout_width="40dp"
					android:layout_height="40dp"
					android:padding="8dp"
					android:src="@drawable/ic_back"
					android:background="?attr/selectableItemBackgroundBorderless"
					android:contentDescription="@null" />

				<TextView
					android:id="@+id/tvTitle"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:layout_weight="1"
					android:text="考试记录"
					android:textSize="18sp"
					android:textStyle="bold"
					android:textColor="@color/text_primary"
					android:layout_marginStart="4dp" />
			</LinearLayout>
		</androidx.appcompat.widget.Toolbar>
	</com.google.android.material.appbar.AppBarLayout>

	<androidx.core.widget.NestedScrollView
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">

		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:padding="16dp">

			<!-- 统计卡片 -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="12dp"
				app:cardElevation="0dp"
				app:cardCornerRadius="16dp"
				app:strokeColor="@color/card_stroke"
				app:strokeWidth="1dp"
				app:cardBackgroundColor="@color/surface">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					android:padding="16dp">

					<LinearLayout
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:orientation="vertical"
						android:gravity="center">

						<TextView
							android:id="@+id/tvStatExamCount"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="22sp"
							android:textStyle="bold"
							android:textColor="@color/primary"
							android:text="0" />

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="考试次数"
							android:textSize="11sp"
							android:textColor="@color/text_hint" />
					</LinearLayout>

					<View
						android:layout_width="1dp"
						android:layout_height="40dp"
						android:background="@color/divider" />

					<LinearLayout
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:orientation="vertical"
						android:gravity="center">

						<TextView
							android:id="@+id/tvStatAvgScore"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="22sp"
							android:textStyle="bold"
							android:textColor="@color/success_dark"
							android:text="--" />

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="平均分"
							android:textSize="11sp"
							android:textColor="@color/text_hint" />
					</LinearLayout>

					<View
						android:layout_width="1dp"
						android:layout_height="40dp"
						android:background="@color/divider" />

					<LinearLayout
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:layout_weight="1"
						android:orientation="vertical"
						android:gravity="center">

						<TextView
							android:id="@+id/tvStatMaxScore"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:textSize="22sp"
							android:textStyle="bold"
							android:textColor="@color/warning"
							android:text="--" />

						<TextView
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="最高分"
							android:textSize="11sp"
							android:textColor="@color/text_hint" />
					</LinearLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

			<!-- 查看错题按钮 -->
			<com.google.android.material.button.MaterialButton
				android:id="@+id/btnViewWrongQuestions"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="12dp"
				android:text="查看错题记录"
				android:textSize="14sp"
				style="@style/Widget.MaterialComponents.Button.OutlinedButton"
				app:strokeColor="@color/error"
				android:textColor="@color/error" />

			<!-- 记录列表卡片 -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				app:cardElevation="0dp"
				app:cardCornerRadius="16dp"
				app:strokeColor="@color/card_stroke"
				app:strokeWidth="1dp"
				app:cardBackgroundColor="@color/surface">

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">

					<TextView
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="历次考试记录"
						android:textSize="13sp"
						android:textColor="@color/text_secondary"
						android:paddingHorizontal="16dp"
						android:paddingTop="14dp"
						android:paddingBottom="8dp" />

					<View
						android:layout_width="match_parent"
						android:layout_height="1dp"
						android:background="@color/divider" />

					<LinearLayout
						android:id="@+id/recordListContainer"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="vertical" />

					<TextView
						android:id="@+id/tvNoRecords"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="该学生暂无考试记录"
						android:textSize="13sp"
						android:textColor="@color/text_hint"
						android:gravity="center"
						android:padding="24dp"
						android:visibility="gone" />

				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

		</LinearLayout>
	</androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
