<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvEditTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="编辑题目"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="题目内容"
        style="@style/Widget.SmartQuiz.TextInput">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="6"
            android:gravity="top" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 选项编辑区（选择题时显示） -->
    <LinearLayout
        android:id="@+id/layoutEditOptions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- 题目图片区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <ImageView
            android:id="@+id/ivEditImage"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:scaleType="centerCrop"
            android:background="#F0F0F0"
            android:visibility="gone"
            android:contentDescription="题目图片" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPickImage"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📷 添加图片"
                android:textSize="13sp"
                style="@style/Widget.SmartQuiz.Button.Outlined" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemoveImage"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="删除图片"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginTop="4dp"
                style="@style/Widget.SmartQuiz.Button.Outlined" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="正确答案"
        style="@style/Widget.SmartQuiz.TextInput">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:hint="解析（可选）"
        style="@style/Widget.SmartQuiz.TextInput">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etEditExplanation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:maxLines="4"
            android:gravity="top" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="取消"
            android:textSize="15sp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.SmartQuiz.Button.Outlined" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="保存"
            android:textSize="15sp"
            style="@style/Widget.SmartQuiz.Button" />
    </LinearLayout>

</LinearLayout>

</androidx.core.widget.NestedScrollView>